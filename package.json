{
  "name": "simple-gif-editor",
  "version": "0.1.0",
  "description": "A simple macOS GIF editor — crop, mosaic, frame reduction for Kap recordings",
  "main": "dist/main/main/index.js",
  "private": true,
  "scripts": {
    "dev": "vite build --mode development && electron .",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "npm run build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Takumi KOSHII",
  "license": "UNLICENSED",
  "type": "commonjs",
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
